# Copy this file to ".env" and fill in your own values.
# The real .env is gitignored so secrets never get committed.

# Flask
SECRET_KEY=change-me-to-a-random-string

# MySQL database (optional).
# If MySQL is unreachable, EventLens still works — reports just aren't
# persisted to history between restarts.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password-here
DB_NAME=eventlens
